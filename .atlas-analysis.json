  "keyFeatures": [
    "Real-time voice calls with OpenAI Realtime API",
    "Twilio integration for phone infrastructure",
    "ClawdBot integration for command execution via OpenClaw Gateway",
    "Intelligent conversation brain with intent understanding",
    "Background service with auto-restart and scheduling",
    "Telegram live transcripts",
    "Webhook tunneling support (ngrok/Cloudflare)",
    "Incoming and outgoing call handling"
  ],
  "publicApiSurface": [
    "agenticai server - Start webhook server",
    "agenticai trigger - Initiate outbound call",
    "agenticai bot - Connect to OpenClaw Gateway terminal",
    "agenticai schedule list - List configured schedules",
    "agenticai schedule run - Execute schedule immediately",
    "agenticai service install - Install as background service",
    "agenticai service start/stop/restart - Manage service",
    "agenticai service status - Check service status",
    "agenticai service logs - View service logs",
    "agenticai tunnel start - Start tunnel for webhooks",
    "agenticai status - Show system status",
    "agenticai setup - Interactive setup wizard",
    "agenticai test-connection - Test all service connections",
    "CallManager - Manage call lifecycle",
    "ConversationBrain - Intent understanding and memory",
    "AudioBridge - Audio format conversion and routing",
    "GatewayClient - OpenClaw Gateway WebSocket client",
    "POST /api/call - Initiate call via REST",
    "GET /api/calls - List active calls",
    "POST /api/calls/{id}/end - End active call"
  ]
